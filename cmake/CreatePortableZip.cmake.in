file(MAKE_DIRECTORY "@SW_PACKAGE_OUTPUT_DIR@")
file(REMOVE_RECURSE "@SW_PORTABLE_STAGE_DIR@")
file(MAKE_DIRECTORY "@SW_PORTABLE_STAGE_DIR@")
file(REMOVE "@SW_PORTABLE_ARCHIVE@")

set(SW_PORTABLE_DESTINATION "@SW_PORTABLE_STAGE_DIR@/@SW_PORTABLE_FOLDER_NAME@")
file(COPY "@SW_INSTALL_STAGE_DIR@" DESTINATION "@SW_PORTABLE_STAGE_DIR@")
file(RENAME "@SW_PORTABLE_STAGE_DIR@/install-root" "${SW_PORTABLE_DESTINATION}")

execute_process(
    COMMAND "@CMAKE_COMMAND@" -E tar cf "@SW_PORTABLE_ARCHIVE@" --format=zip "@SW_PORTABLE_FOLDER_NAME@"
    WORKING_DIRECTORY "@SW_PORTABLE_STAGE_DIR@"
    RESULT_VARIABLE SW_PORTABLE_ZIP_RESULT
)

if(NOT SW_PORTABLE_ZIP_RESULT EQUAL 0)
    message(FATAL_ERROR "Portable ZIP creation failed with exit code ${SW_PORTABLE_ZIP_RESULT}")
endif()