{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 15,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "vs2022-debug",
            "displayName": "VS 2022 Debug",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "SW_REQUIRE_RUBBERBAND": "ON",
                "RUBBERBAND_SOURCE_DIR": "${sourceDir}/third_party/rubberband"
            }
        },
        {
            "name": "vs2022-release",
            "displayName": "VS 2022 Release",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
